# Variables de entorno para el proyecto
# Copia este archivo a .env y rellena los valores reales

# URL base del sitio (sin trailing slash)
SITE_URL=https://ejemplo.com

# Configuración de SEO
SITE_NAME=Mi Página Personal
SITE_DESCRIPTION=Un sitio web personal minimalista construido con Astro y Tailwind CSS
SITE_AUTHOR=Tu Nombre

# Redes sociales (opcionales)
GITHUB_USERNAME=tuusuario
TWITTER_USERNAME=tuusuario
LINKEDIN_USERNAME=tuusuario

# Analytics (opcional)
# GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# Configuración de desarrollo
PUBLIC_MODE=development
# PUBLIC_API_URL=https://api.ejemplo.com

# NOTA: Nunca commitees el archivo .env real con valores sensibles