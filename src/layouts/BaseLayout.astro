---
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{Astro.props.title || 'Hola Mundo'}</title>
    <!-- Favicon moderno SVG para navegadores que lo soportan -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- Favicon ICO para compatibilidad con navegadores antiguos -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <!-- Shortcut icon para máxima compatibilidad -->
    <link rel="shortcut icon" href="/favicon.ico" />
    <style>
      body {
        font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, 'Noto Sans', sans-serif, 'Apple Color Emoji', 'Segoe UI Emoji', 'Segoe UI Symbol', 'Noto Color Emoji';
      }
    </style>
  </head>
  
  <body class="antialiased selection:bg-zinc-800 selection:text-zinc-200 text-zinc-100">
    <div class="min-h-screen flex flex-col">
      
      <main class="flex-grow">
        <div class="mx-auto max-w-2xl px-6 py-20">
          <slot />
        </div>
      </main>
      
    </div>
  </body>
</html>